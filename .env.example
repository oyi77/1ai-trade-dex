# PolyEdge Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments — do NOT commit .env to git.

# ============================================================
# Mode
# ============================================================
# Trading mode: paper (simulation), testnet, or live
TRADING_MODE=paper

# Starting bankroll in USD (used for Kelly sizing)
INITIAL_BANKROLL=1000.0

# Signal approval: manual (always ask), auto_approve, auto_deny
SIGNAL_APPROVAL_MODE=manual

# ============================================================
# Polymarket Auth (required for live order placement)
# ============================================================
# Your wallet private key (hex, 0x-prefixed)
# NEVER share or commit this value.
# This is the ONLY credential required — API keys are auto-derived.
POLYMARKET_PRIVATE_KEY=

# Optional: Pre-derived API credentials (auto-derived if omitted)
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# Polymarket Builder Program (gasless trading via proxy wallet)
# POLYMARKET_SIGNATURE_TYPE=0
# Public wallet/proxy address used to fetch live Polymarket position value.
# Safe to document; not a private key or API credential.
# POLYMARKET_WALLET_ADDRESS=
# POLYMARKET_BUILDER_API_KEY=
# POLYMARKET_BUILDER_SECRET=
# POLYMARKET_BUILDER_PASSPHRASE=
# POLYMARKET_BUILDER_ADDRESS=
# POLYMARKET_RELAYER_API_KEY=
# POLYMARKET_RELAYER_API_KEY_ADDRESS=

# ============================================================
# Telegram Bot (optional — required for signal alerts)
# ============================================================
# Create a bot at https://t.me/BotFather, paste token here.
TELEGRAM_BOT_TOKEN=

# Your Telegram user/chat ID(s) — comma-separated.
# Get your ID by messaging @userinfobot.
TELEGRAM_ADMIN_CHAT_IDS=

# ============================================================
# Kalshi (optional — for Kalshi weather markets)
# ============================================================
KALSHI_ENABLED=false
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ============================================================
# AI (Groq LLM for signal reasoning, classification, and parsing)
# ============================================================
# Get a FREE Groq API key:
#   1. Sign up at https://console.groq.com
#   2. Go to https://console.groq.com/keys
#   3. Create a key and paste below
# The free tier provides fast LLM inference — no credit card required.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
AI_DAILY_BUDGET_USD=1.0

# ============================================================
# Web Search (AI market research)
# ============================================================
# Provider selection: tavily, exa, serper, duckduckgo
# DuckDuckGo is free (no API key) and used as final fallback
WEBSEARCH_ENABLED=true
WEBSEARCH_PROVIDER=tavily
WEBSEARCH_FALLBACK_PROVIDER=duckduckgo
WEBSEARCH_MAX_RESULTS=5
WEBSEARCH_TIMEOUT_SECONDS=15.0

# Tavily (https://tavily.com - 1000 free searches/month)
TAVILY_API_KEY=

# Exa (https://exa.ai - neural semantic search)
EXA_API_KEY=

# Serper (https://serper.dev - Google SERP API)
SERPER_API_KEY=

# ============================================================
# Database
# ============================================================
DATABASE_URL=sqlite:///./tradingbot.db
# For production, use PostgreSQL (recommended) or MySQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/polyedge
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/polyedge

# ============================================================
# Redis (Multi-Instance WebSocket Support)
# ============================================================
# Redis URL for pub/sub across multiple backend instances
REDIS_URL=redis://localhost:6379

# Enable Redis pub/sub (set to true for multi-instance deployments)
REDIS_ENABLED=false

# ============================================================
# Weather Trading
# ============================================================
WEATHER_ENABLED=true
# Comma-separated city keys (static from CITY_CONFIG, or leave empty for ALL cities)
# Any city from Polymarket temperature markets is auto-discovered via geocoding.
WEATHER_CITIES=nyc,chicago,miami,dallas,seattle,atlanta,los_angeles,denver,london,seoul,tokyo

# Minimum edge to act on (8% = solid signal for temperature markets)
WEATHER_MIN_EDGE_THRESHOLD=0.08
WEATHER_MAX_ENTRY_PRICE=0.70
WEATHER_MAX_TRADE_SIZE=100.0

# ============================================================
# Copy Trader
# ============================================================
# Kelly fraction (0.15 = quarter-Kelly, conservative)
KELLY_FRACTION=0.15

# ============================================================
# Risk Management
# ============================================================
DAILY_LOSS_LIMIT=300.0
MAX_TRADE_SIZE=75.0

# Edge threshold — BTC strategies typically show 3-6% edge; 0.30 default was too restrictive
MIN_EDGE_THRESHOLD=0.03

# Max trades per scheduling window (per mode) — raised from 2 to unblock throughput
MAX_TRADES_PER_WINDOW=20

# Max trades per scan cycle (scheduling_strategies.py) — env-overridable
MAX_TRADES_PER_SCAN=10

# Auto-trader batch size — max signals fetched per auto_trader_job cycle
# Job worker — enables APScheduler strategy cycles, AGI evolution, health checks, etc.
# Must be true for trading to occur (strategies need scheduled execution)
JOB_WORKER_ENABLED=true

AUTO_TRADER_BATCH_SIZE=100

# Per-mode circuit breaker toggles (JSON-like dict syntax)
# Paper mode defaults to breaker-disabled so it runs infinitely for backtest/improvement
# Live and testnet default to breaker-enabled for capital safety
DRAWDOWN_BREAKER_ENABLED_PER_MODE={"paper": false, "testnet": true, "live": true}
DAILY_LOSS_LIMIT_ENABLED_PER_MODE={"paper": false, "testnet": true, "live": true}

# ============================================================
# Wave 1: Foundation (Self-Improvement & Activity Logging)
# ============================================================
# MiroFish signal API endpoint
MIROFISH_API_URL=https://api.mirofish.example/v1

# MiroFish authentication
MIROFISH_API_KEY=your-mirofish-api-key

# Activity log retention in days
ACTIVITY_LOG_RETENTION_DAYS=90

# Require manual approval for self-improvement proposals
PROPOSAL_APPROVAL_REQUIRED=true

# ============================================================
# Wave 1: Timeouts & Performance
# ============================================================
# MiroFish API timeout in seconds
MIROFISH_API_TIMEOUT=10

# Proposal execution timeout in seconds
PROPOSAL_EXECUTION_TIMEOUT=5

# Debate cycle upper bound in seconds
DEBATE_CYCLE_TIMEOUT=30

# Concurrent write safety timeout in seconds
ACTIVITY_DB_TRANSACTION_TIMEOUT=3

# Real-time activity WebSocket latency SLA in milliseconds
WEBSOCKET_ACTIVITY_LATENCY_SLA=500

# ============================================================
# AGI Autonomy (full automatic operation)
# ============================================================
# Allow paper→live promotion without human approval (default: false for safety)
AGI_AUTO_PROMOTE=false

# Auto-enable strategies in StrategyConfig when promoted to live
AGI_AUTO_ENABLE=false

# How often to evaluate experiment promotions (hours)
AGI_PROMOTION_INTERVAL_HOURS=6

# Enable health-based auto-disable for underperforming strategies
AGI_STRATEGY_HEALTH_ENABLED=true

# Enable daily bankroll reallocation across ranked strategies
AGI_BANKROLL_ALLOCATION_ENABLED=false

# Bankroll rebalancing frequency (days)
AGI_BANKROLL_ALLOCATION_INTERVAL_DAYS=1

# AGI health check — validates strategy health, data freshness, budget, orphans
AGI_HEALTH_CHECK_ENABLED=true
AGI_HEALTH_CHECK_INTERVAL_MINUTES=15

# AGI nightly review — writes daily markdown log with calibration + improvement plan
AGI_NIGHTLY_REVIEW_ENABLED=true
AGI_NIGHTLY_REVIEW_HOUR=2

# Strategy rehabilitation — auto re-enables disabled strategies after validation
AGI_REHABILITATION_ENABLED=true

# Fronttest — minimum paper-trading days before a param change can go live
AGI_FRONTTEST_DAYS=14
AGI_FRONTTEST_MIN_TRADES=10

# AGI Improvement Cycle — alert on critical error accumulation
STATS_REPORT_CRITICAL_ERRORS=false

# Historical data collector — BTC candles, market outcomes, weather snapshots
HISTORICAL_DATA_COLLECTOR_ENABLED=true
HISTORICAL_DATA_COLLECTOR_INTERVAL_HOURS=6

# AGI Health Check thresholds
AGI_HEALTH_STALE_STRATEGY_HOURS=2.0
AGI_HEALTH_DATA_FRESHNESS_HOURS=24.0
AGI_HEALTH_BUDGET_NEAR_LIMIT_PCT=0.8
AGI_HEALTH_ORPHAN_MAX_AGE_DAYS=7

# AGI Nightly Review
AGI_NIGHTLY_REVIEW_OUTPUT_DIR=docs/agi-log
AGI_NIGHTLY_REVIEW_LOOKBACK_DAYS=7

# AGI Rehabilitation thresholds
AGI_REHAB_COOLDOWN_DAYS=7
AGI_REHAB_MIN_TRADES=10
AGI_REHAB_WIN_RATE_THRESHOLD=0.50

# AGI Fronttest thresholds
AGI_FRONTTEST_MIN_WIN_RATE=0.40

# ── LIVE_TRIAL phase (AGI-2) ──────────────────────────────────────────────────
# Insert a bounded live trial between paper validation and full live promotion.
LIVE_TRIAL_ENABLED=true
# Fraction of bankroll allocated during the trial (default 1%)
LIVE_TRIAL_BANKROLL_PCT=0.01
# Minimum days in live trial before promotion decision
LIVE_TRIAL_DURATION_DAYS=7
# Live performance must be >= paper performance * this threshold to promote
LIVE_TRIAL_DEGRADATION_THRESHOLD=0.80

# ── Demotion → improvement loop (AGI-3) ──────────────────────────────────────
# Max improvement cycles before a strategy is permanently RETIRED
AGI_MAX_IMPROVEMENT_ATTEMPTS=3

# ── LLM strategy synthesis (AGI-4) ───────────────────────────────────────────
# Max USD per day spent on LLM calls for strategy synthesis
AGI_SYNTHESIS_DAILY_BUDGET=2.00

# ── Forensics overhaul for broken strategies (AGI-7) ─────────────────────────
# When true, fundamentally broken strategies get a full parameter overhaul
# instead of being permanently excluded from improvement cycles
AGI_BROKEN_STRATEGY_OVERHAUL_ENABLED=true

# ── Calibration drift detection (AI-3) ───────────────────────────────────────
# Brier score above this threshold triggers model retraining
AGI_BRIER_DRIFT_THRESHOLD=0.25
# Minimum settled trades required before running calibration check
AGI_CALIBRATION_MIN_SAMPLES=30
# How often to run the calibration check job (hours)
AGI_CALIBRATION_CHECK_INTERVAL_HOURS=6

# Autonomous Promoter thresholds
AGI_PROMOTER_SHADOW_MIN_TRADES=100
AGI_PROMOTER_SHADOW_MIN_DAYS=7
AGI_PROMOTER_SHADOW_MIN_WIN_RATE=0.45
AGI_PROMOTER_SHADOW_MAX_DRAWDOWN=0.25
AGI_PROMOTER_PAPER_MIN_TRADES=50
AGI_PROMOTER_PAPER_MIN_DAYS=3
AGI_PROMOTER_PAPER_MIN_WIN_RATE=0.50
AGI_PROMOTER_PAPER_MIN_SHARPE=0.5
AGI_PROMOTER_PAPER_MAX_DRAWDOWN=0.20

# Self Debugger
SELF_DEBUGGER_MAX_RECOVERY_ATTEMPTS=3

# Monitoring
MONITORING_BACKUP_MAX_AGE_HOURS=2.0
MONITORING_PNL_TOLERANCE_PCT=0.02

# Alert Webhooks (optional — leave blank to disable)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Risk profile preset: safe, normal, aggressive, extreme (overrides risk settings)
RISK_PROFILE=normal

# Polygon RPC URL (for on-chain balance checks)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# Brain / BK-Hub integration URL
BRAIN_API_URL=http://localhost:9099

# RSS News Feed URLs (comma-separated)
RSS_FEED_URLS=https://feeds.bbci.co.uk/news/rss.xml,https://feeds.reuters.com/reuters/businessNews,https://www.federalreserve.gov/feeds/press_all.xml,https://cointelegraph.com/rss,https://coindesk.com/arc/outboundfeeds/rss/

# Arb strategy thresholds
ARB_MIN_PROFIT=0.02
ARB_MAX_RETRIES=3
ARB_CIRCUIT_BREAKER_THRESHOLD=5
ARB_CIRCUIT_BREAKER_TIMEOUT=60.0
ARB_POLYMARKET_FEE=0.01
ARB_KALSHI_FEE=0.01
ARB_DEFAULT_FEE_RATE=0.02
ARB_DEFAULT_MIN_SPREAD=0.03

# Whale frontrun thresholds
WHALE_FRONTRUN_MIN_SIZE=10000.0
WHALE_FRONTRUN_MIN_SCORE=0.8
WHALE_FRONTRUN_MAX_RECONNECT=5
WHALE_FRONTRUN_DELAY_MS=50
WHALE_FRONTRUN_SELL_DELAY_MS=1000

# Universal scanner thresholds
SCANNER_PAGE_SIZE=500
SCANNER_SEMAPHORE_LIMIT=50
SCANNER_MIN_EDGE=0.02
SCANNER_STALE_THRESHOLD_SECONDS=5.0
SCANNER_MAX_MARKETS=10000

# Order executor thresholds
ORDER_EXECUTOR_MIN_WHALE_SIZE=50.0
ORDER_EXECUTOR_MIN_DAYS_TO_RESOLUTION=7

# Line movement detector confidence
LINE_MOVE_BASE_CONFIDENCE=0.5
LINE_MOVE_HUGE_THRESHOLD=15.0
LINE_MOVE_HUGE_BOOST=0.2
LINE_MOVE_LARGE_THRESHOLD=10.0
LINE_MOVE_LARGE_BOOST=0.15
LINE_MOVE_MEDIUM_THRESHOLD=7.0
LINE_MOVE_MEDIUM_BOOST=0.1
LINE_MOVE_SMALL_BOOST=0.05
LINE_MOVE_HIGH_VOL_THRESHOLD=100000.0
LINE_MOVE_HIGH_VOL_BOOST=0.1
LINE_MOVE_MED_VOL_THRESHOLD=50000.0
LINE_MOVE_MED_VOL_BOOST=0.05
LINE_MOVE_NEWS_BOOST=0.1
LINE_MOVE_MAX_CONFIDENCE=0.95

# Weather EMOS thresholds
WEATHER_KELLY_FRACTION=0.15
WEATHER_MAX_BANKROLL_FRACTION=0.05

# External API base URLs (override only if using alternative endpoints)
GAMMA_API_URL=https://gamma-api.polymarket.com
DATA_API_URL=https://data-api.polymarket.com
DATA_API_VERSION=v1
CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_BASE_URL=https://polymarket.com
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2
GOLDSKY_API_URL=https://api.goldsky.com/api/public/project_cl6mb8i9h0003e201j6li0diw/subgraphs/orderbook-subgraph/0.0.1/gn
BINANCE_API_URL=https://api.binance.com/api/v3
COINBASE_API_URL=https://api.exchange.coinbase.com
KRAKEN_API_URL=https://api.kraken.com/0/public
BYBIT_API_URL=https://api.bybit.com/v5/market
COINGECKO_API_URL=https://api.coingecko.com/api/v3
OPEN_METEO_API_URL=https://api.open-meteo.com/v1
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
NWS_API_URL=https://api.weather.gov/gridpoints
NWS_BASE_URL=https://api.weather.gov
BINANCE_KLINES_URL=https://api.binance.com/api/v3/klines
RESEARCH_RSS_FEEDS=https://polymarket.com/feed.xml,https://metaculus.com/feed/
POLYMARKET_RELAYER_URL=https://relayer-v2.polymarket.com
POLYMARKET_WS_CLOB_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WS_USER_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user
POLYMARKET_WS_RTDS_URL=wss://ws-live-data.polymarket.com
POLYMARKET_WS_WHALE_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WS_ORDERBOOK_URL=wss://ws.polymarket.com/orderbook
QUICKNODE_RPC_URL=https://rpc-mainnet.matic.quiknode.pro
OPEN_METEO_ENSEMBLE_URL=https://ensemble-api.open-meteo.com/v1/ensemble
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
TELEGRAM_API_BASE=https://api.telegram.org
MIROFISH_API_URL=https://polyedge-mirofish-api.aitradepulse.com
TAVILY_API_URL=https://api.tavily.com/search
EXA_API_URL=https://api.exa.ai/search
SERPER_API_URL=https://google.serper.dev/search
DDG_HTML_URL=https://html.duckduckgo.com/html/

# CLOB order size limits
MIN_ORDER_USDC=5.0
PAPER_MIN_ORDER_USDC=1.0

# Paper trading slippage simulation (disabled by default for backward compatibility)
# Set PAPER_SLIPPAGE_BPS > 0 to enable realistic paper trading simulation
PAPER_SLIPPAGE_BPS=0.0
PAPER_MIN_SLIPPAGE_BPS=5.0
PAPER_SIZE_IMPACT_FACTOR=0.5
PAPER_CLOB_FEE_RATE=0.02
PAPER_MIN_DEPTH_USD=0.0
PAPER_RANDOM_SLIPPAGE=false

# Safe parameter tuner thresholds
SAFE_TUNER_MAX_CHANGE_PCT=0.10
SAFE_TUNER_MIN_TRADES_FOR_TUNING=20
SAFE_TUNER_REVERT_SIGMA_THRESHOLD=2.0

# HFT risk parameters
HFT_POSITION_SIZE_PCT=0.25
HFT_MAX_POSITION_USD=1000.0

# ============================================================
# Gap Fixes (from master_prompt.md Part 12)
# ============================================================
# G3: Forensics auto-mutation of StrategyConfig params (default: propose-only)
FORENSICS_AUTO_MUTATE=false

# G2/G6: Wire RegimeDetector to confidence thresholds
REGIME_ROUTING_ENABLED=true

# G10: SSE event type filtering for dashboard
SSE_EVENT_TYPE_FILTER_ENABLED=true

# ============================================================
# WebSocket Pipeline (from master_prompt.md Phase E)
# ============================================================
POLYMARKET_WS_ENABLED=true
POLYMARKET_WS_SUBSCRIPTION_LIMIT=200
WS_HANDLER_TIMEOUT_MS=100

# ============================================================
# Pair Cost Arbitrage (from master_prompt.md Phase F)
# ============================================================
ENABLE_PAIR_COST_ARB=true
MIN_ARB_SPREAD=0.005

# ============================================================
# External API Rate Limits (for external data providers)
# ============================================================
# Rate limits for external API calls:
#   - Gamma API (Polymarket): requests per minute
#   - Kalshi API: requests per minute
#   - Crypto exchanges (Binance, Coinbase, Kraken): requests per minute
RATE_LIMIT_GAMMA=100
RATE_LIMIT_KALSHI=30
RATE_LIMIT_CRYPTO=60
RATE_LIMIT_BACKOFF_BASE=2.0
RATE_LIMIT_MAX_DELAY=60.0

# ============================================================
# Evolution Engine (from master_prompt.md Part 7/12)
# ============================================================
# Master toggle — start false, enable manually after Phase A-G deployed and validated
EVOLUTION_ENGINE_ENABLED=false
AGI_MUTATION_INTERVAL_HOURS=6
AGI_CROSSOVER_INTERVAL_HOURS=24
AGI_POPULATION_SIZE=20
AGI_MUTATION_RATE=0.10
GENOME_POPULATION_TARGET=50
MUTATION_CYCLE_INTERVAL_HOURS=1
CROSSOVER_CYCLE_INTERVAL_HOURS=6
NECROMANCY_INTERVAL_DAYS=7
GENOME_RAMP_MIN_TRADES=20
GENOME_INITIAL_ALLOCATION_PCT=0.01
FORENSICS_MAX_MUTATIONS_PER_DAY=1

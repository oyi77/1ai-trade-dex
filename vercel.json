{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "polymarket-kalshi-weather-bot",
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/docs/(.*\\.[a-zA-Z0-9]+)$",
      "dest": "/frontend/docs/$1"
    },
    {
      "src": "/docs/?$",
      "dest": "/frontend/docs/index.html"
    },
    {
      "src": "/docs/(.*[^/])$",
      "dest": "/frontend/docs/$1.html"
    },
    {
      "src": "/docs/(.*)/$",
      "dest": "/frontend/docs/$1.html"
    },
    {
      "src": "/assets/(.*)$",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(.*\\.[a-zA-Z0-9]+)$",
      "dest": "/frontend/$1"
    },
    {
      "src": "/$",
      "dest": "/frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
